# ── App URLs ──────────────────────────────────────────────────────────────────
# Public URL of your deployed API (no trailing slash).
QMOL_API_BASE=https://qua-22p1.onrender.com
# Email shown to customers and in delivery emails.
QMOL_CONTACT_EMAIL=hi@qmol.app
# Admin dashboard token (any random string).
QMOL_ADMIN_TOKEN=

# ── Stripe (required for paid subscriptions) ───────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys and the Products section.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Create one recurring-price product in Stripe for each tier, paste the price IDs:
STRIPE_PRICE_RESEARCH=price_...      # $49/month
STRIPE_PRICE_COMMERCIAL=price_...    # $299/month
STRIPE_PRICE_REDISTRIBUTION=price_... # $999/month
# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Where Stripe sends the user after checkout (must be your deployed domain)
SUCCESS_URL=https://qua-22p1.onrender.com/checkout.html?success=1
CANCEL_URL=https://qua-22p1.onrender.com/checkout.html

# ── Email delivery (optional — Mailgun) ───────────────────────────────────────
# If set, API keys + download links are emailed automatically on purchase.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=Q-Mol <hi@qmol.app>

# ── HuggingFace (required for auto-publish) ───────────────────────────────────
HF_TOKEN=hf_xxx_your_write_token_here
HF_REPO_ID=yourusername/q-mol-dataset
HF_PRIVATE=true

# ── PubChem ingestion ─────────────────────────────────────────────────────────
PUBCHEM_START_CID=1
PUBCHEM_BATCH_SIZE=50
MAX_HEAVY_ATOMS=8

# ── Compute ───────────────────────────────────────────────────────────────────
BASIS_SET=sto-3g
USE_VQE_UP_TO_QUBITS=12
MAX_CPU_SECONDS_PER_MOL=120

# ── Publishing cadence ────────────────────────────────────────────────────────
PUBLISH_EVERY_N_MOLECULES=100
SNAPSHOT_EVERY_HOURS=6

# ── Kaggle auto-publish (optional) ────────────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET_SLUG=qmol-molecular-descriptors

# ── Gumroad auto-upload (optional) ────────────────────────────────────────────
# Create product first, then put its ID + an access token here.
GUMROAD_ACCESS_TOKEN=
GUMROAD_PRODUCT_ID=

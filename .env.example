# HuggingFace (required for auto-publish)
HF_TOKEN=hf_xxx_your_write_token_here
HF_REPO_ID=yourusername/q-mol-dataset
HF_PRIVATE=true

# PubChem ingestion
PUBCHEM_START_CID=1
PUBCHEM_BATCH_SIZE=50
MAX_HEAVY_ATOMS=8

# Compute
BASIS_SET=sto-3g
USE_VQE_UP_TO_QUBITS=12
MAX_CPU_SECONDS_PER_MOL=120

# Publishing cadence
PUBLISH_EVERY_N_MOLECULES=100
SNAPSHOT_EVERY_HOURS=6

# Kaggle auto-publish (optional)
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET_SLUG=qmol-molecular-descriptors

# Gumroad auto-upload (optional)
# Create product first, then put its ID + an access token here.
GUMROAD_ACCESS_TOKEN=
GUMROAD_PRODUCT_ID=
